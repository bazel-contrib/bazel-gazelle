load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

# gazelle:prefix example.com/foo

go_library(
    name = "foo",
    srcs = ["foo.go"],
    embedsrcs = ["//sub:data.txt"],
    importpath = "example.com/foo",
    visibility = ["//visibility:public"],
)

go_test(
    name = "foo_test",
    srcs = ["foo_test.go"],
    embed = [":foo"],
    embedsrcs = ["//sub:data.txt"],
)
